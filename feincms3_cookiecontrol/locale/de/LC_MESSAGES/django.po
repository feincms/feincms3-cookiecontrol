#: embedding.py:55
#, python-brace-format
msgctxt "f3cc"
msgid ""
"We would like to show you content from the provider {title}, but respect "
"your privacy. If you agree to the {link_start}provider's privacy "
"policy{link_end}, please click the following button to view the content."
msgstr ""
"Wir möchten Ihnen gerne Inhalte des Anbieters {title} anzeigen, aber "
"respektieren Ihre Privatsphäre. Falls Sie mit der {link_start}Datenschutzerklärung "
"des Anbieters{link_end} einverstanden sind, klicken Sie bitte den folgenden "
"Button, um die Inhalte anzuzeigen."

#: embedding.py:57
msgctxt "f3cc"
msgid "Show the content"
msgstr "Inhalt anzeigen"

#: embedding.py:109
msgctxt "f3cc"
msgid "Privacy policy"
msgstr "Datenschutzerklärung"

#: models.py:16
msgctxt "f3cc"
msgid "Cookies on Our Website"
msgstr "Cookies auf unserer Website"

#: models.py:19
#, python-brace-format
msgctxt "f3cc"
msgid ""
"We use cookies to enhance the user experience on our website. Read our "
"{link_start}privacy policy{link_end} to find out more about how we use "
"cookies and protect your data."
msgstr ""
"Wir verwenden Cookies, um unsere Website benutzerfreundlich zu gestalten. In "
"unserer {link_start}Datenschutzerklärung{link_end} finden Sie weitere "
"Informationen darüber, wie wir Cookies einsetzen und Ihre Daten schützen."

#: models.py:21
msgctxt "f3cc"
msgid "Accept all cookies"
msgstr "Alle akzeptieren"

#: models.py:22
msgctxt "f3cc"
msgid "Refuse non-essential cookies"
msgstr "Nicht-essentielle Cookies verweigern"

#: models.py:23
msgctxt "f3cc"
msgid "Modify cookie settings"
msgstr "Cookie-Einstellungen anpassen"

#: models.py:62
msgid "technical name"
msgstr "Technischer Name"

#: models.py:64 models.py:71
msgid "script"
msgstr "Skript"

#: models.py:66
msgid "HTML code to inject if cookies are accepted."
msgstr "HTML-Code, falls Cookies akzeptiert werden."

#: models.py:72
msgid "scripts"
msgstr "Skripte"

#: models.py:81
msgid ""
"This doesn't look right. Please start with a HTML tag (e.g. <script>, <div>)."
msgstr ""
"Das sieht nicht korrekt aus. Bitte beginne mit einem HTML-Tag (zB <script>, "
"<div>)."

#: models.py:88
msgid "Entering <noscript> tags doesn't make sense."
msgstr "Die Eingabe von <noscript> Tags macht keinen Sinn."
